datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

enum UserRole {
  FARMER
  HERDER
  YOUTH_OFFICER
  GOV_ADMIN
  BUYER
  NGO
}

enum ResourceType {
  WATER
  GRAZING
}

enum ResourceStatus {
  DRY
  VIABLE
}

enum RouteStatus {
  ACTIVE
  COMPLETED
}

enum ListingStatus {
  AVAILABLE
  SOLD
}

model User {
  id           String                @id @default(uuid())
  phoneNumber  String                @unique
  password     String?
  role         UserRole
  region       String
  reports      USSD_Report[]
  scans        Crop_Scan[]
  routes       Safe_Route[]          @relation("HerderRoutes")
  listings     Marketplace_Listing[]
  createdAt    DateTime              @default(now())
}

model USSD_Report {
  id           String         @id @default(uuid())
  resourceType ResourceType
  status       ResourceStatus
  latitude     Float
  longitude    Float
  timestamp    DateTime       @default(now())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
}

model Crop_Scan {
  id                String   @id @default(uuid())
  imageUrl          String
  detectedPest      String?
  healthPercentage  Float
  recommendedAction String?
  latitude          Float?
  longitude         Float?
  timestamp         DateTime @default(now())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
}

model Safe_Route {
  id              String      @id @default(uuid())
  destination_lat Float
  destination_lng Float
  assignedHerderId String
  assignedHerder   User       @relation("HerderRoutes", fields: [assignedHerderId], references: [id])
  status          RouteStatus @default(ACTIVE)
  timestamp       DateTime    @default(now())
}

model Marketplace_Listing {
  id           String        @id @default(uuid())
  seedlingType String
  quantity     Int
  priceZMW     Float
  sellerId     String
  seller       User          @relation(fields: [sellerId], references: [id])
  status       ListingStatus @default(AVAILABLE)
  timestamp    DateTime      @default(now())
}
